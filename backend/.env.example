# Flask 配置
FLASK_ENV=development
SECRET_KEY=your-secret-key-here
APP_HOST=0.0.0.0
APP_PORT=5000
APP_DEBUG=true

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=xingyu_cms

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key

# CORS 配置（前端地址，多个用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 文件与请求配置
UPLOAD_FOLDER=D:\path\to\base_web\backend\uploads
MAX_CONTENT_LENGTH=10485760
APPLICATION_RATE_LIMIT_MINUTES=10

# 第三方服务配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token

# 站点默认链接配置
DEFAULT_GITHUB_URL=https://github.com/your-org-or-user
DEFAULT_APPLICATION_GITHUB_URL=https://github.com
